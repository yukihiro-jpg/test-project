# =============================================================================
# 月次財務報告アプリ 環境変数サンプル
# =============================================================================
# このファイルを .env.local にコピーして、実際の値を設定してください
# .env.local は Git にコミットされません（.gitignore 済）

# -----------------------------------------------------------------------------
# 基本設定
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google Cloud
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-project-id

# サービスアカウント JSON を base64 エンコードして貼り付ける
# （Cloud Run ではこの変数を設定すれば OAuth も動作）
GCP_SERVICE_ACCOUNT_BASE64=

# -----------------------------------------------------------------------------
# 認証
# -----------------------------------------------------------------------------
# Google OAuth クライアント ID / Secret
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# セッション暗号化キー（openssl rand -hex 32 で生成）
SESSION_SECRET=

# アプリにログインできる唯一のメールアドレス
ALLOWED_EMAIL=your@gmail.com

# -----------------------------------------------------------------------------
# Firestore
# -----------------------------------------------------------------------------
FIRESTORE_DATABASE_ID=(default)

# -----------------------------------------------------------------------------
# Google Drive（PDF/Excel 保管用）
# -----------------------------------------------------------------------------
# アプリが生成した PDF/Excel を保管する Google Drive フォルダ ID
GOOGLE_DRIVE_FOLDER_ID=

# -----------------------------------------------------------------------------
# Gemini API（AI 叩き台コメント生成）
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# モデル（2.5 Flash 推奨）
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# e-Stat API（ベンチマーク機能）
# -----------------------------------------------------------------------------
# https://www.e-stat.go.jp/mypage/view/api から取得
ESTAT_APP_ID=

# -----------------------------------------------------------------------------
# Gmail API（月次報告メール送信）
# -----------------------------------------------------------------------------
# 送信元メールアドレス（自分の Gmail）
GMAIL_SENDER_EMAIL=

# -----------------------------------------------------------------------------
# 異常値検知のデフォルト閾値
# -----------------------------------------------------------------------------
ANOMALY_THRESHOLD_MOM=10     # 前月比 ±N%
ANOMALY_THRESHOLD_YOY=20     # 前年同月比 ±N%
