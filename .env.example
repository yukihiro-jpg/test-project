# Google Cloud Service Account credentials (JSON key contents)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Shared Drive ID
GOOGLE_SHARED_DRIVE_ID=your_shared_drive_id

# Google Drive root folder ID (年末調整ルートフォルダ in shared drive)
GOOGLE_ROOT_FOLDER_ID=your_root_folder_id

# Gmail notification settings
NOTIFICATION_EMAIL=your-email@gmail.com

# App URL (for QR code generation)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# -------------------------------------------------------
# Notion API 連携（税務業務管理）
# -------------------------------------------------------
# 1. https://www.notion.so/my-integrations でIntegrationを作成し、APIキーをコピー
# 2. Notionで親ページを作成し、Integrationのアクセス権を付与
# 3. npm run notion:setup を実行してデータベースを自動作成
# 4. 出力されたDB IDを以下に貼り付ける

# Notion Integration のシークレットキー (secret_xxx...)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# データベースを作成する親ページのID (URLの末尾32文字)
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 以下は npm run notion:setup 実行後に自動出力されるIDをコピーする
NOTION_DB_CLIENTS=
NOTION_DB_PROGRESS=
NOTION_DB_DOCUMENTS=
NOTION_DB_TASKS=
